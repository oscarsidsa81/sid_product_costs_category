<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_product_template_form_sid_cost" model="ir.ui.view">
            <field name="name">product.template.form.sid.cost</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="priority">2000</field>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='standard_price']" position="after">
                    <field name="sid_cost_category" string="Coste Recomendado"/>
                    <field name="sid_cost_ton_category"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
